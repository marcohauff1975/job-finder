[Unit]
Description=Job Finder Streamlit App
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/crewai-starter
ExecStart=/home/ubuntu/crewai-starter/venv/bin/streamlit run streamlit_app.py --server.port 8501 --server.address 127.0.0.1 --server.headless true
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
