ANTHROPIC_API_KEY=
SERPER_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
# owner/name of the GitHub repo the CTO Cockpit Connectivity/Cost tabs
# read Actions variables and Actions billing for - defaults to
# marcohauff1975/job-finder if unset. Does NOT affect PR creation/
# validation, which is hardcoded to marcohauff1975/job-finder elsewhere.
GITHUB_REPO=
# Fine-grained GitHub PAT scoped to just "Actions: Read and write" on this
# repo - do not reuse GITHUB_ACTIONS_TOKEN (a different, read-only token)
# or a broader classic PAT here. See req2prod_deploy_mode.py's module docstring.
GITHUB_VARIABLES_TOKEN=
# Fine-grained GitHub PAT scoped to "Contents: Read and write" +
# "Pull requests: Read and write" on this repo only - lets
# software_engineer push feature branches and open PRs even in
# environments (like production) where the ambient git remote is
# deliberately read-only. See req2prod/tools/feature_build_ops.py's
# module docstring.
GITHUB_PR_PUSH_TOKEN=
